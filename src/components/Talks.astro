---
import { siteConfig } from "../config";
const hasTalks = siteConfig.talks && siteConfig.talks.length > 0;

const linkLabels: Record<string, string> = {
  video: "Video",
  event: "Event",
  blog: "Blog",
  slides: "Slides",
};
---

{
  hasTalks && (
    <section id="talks" class="p-8 sm:p-12 md:p-16 lg:p-24">
      <div>
        <h2 class="text-3xl sm:text-4xl md:text-5xl xl:text-7xl font-bold text-gray-900 dark:text-gray-100 mb-3">
          Talks
        </h2>
        <div
          class="w-[75px] h-[5px] mb-10 rounded-full"
          style={`background-color: ${siteConfig.accentColor}`}
        />

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          {siteConfig.talks.map((talk) => {
            const activeLinks = Object.entries(talk.links).filter(([, v]) => v);
            return (
              <div class="flex flex-col bg-white dark:bg-gray-800 rounded-2xl border border-gray-200 dark:border-gray-700 overflow-hidden shadow-sm hover:shadow-md transition-shadow duration-300">
                {/* Thumbnail */}
                <div class="relative overflow-hidden bg-gray-100 dark:bg-gray-700" style="aspect-ratio: 16/9;">
                  <img
                    src={talk.thumbnail}
                    alt={`Thumbnail for: ${talk.title}`}
                    class="w-full h-full object-cover"
                    loading="lazy"
                  />
                  {/* Play button overlay */}
                  {talk.links.video && (
                    <a
                      href={talk.links.video}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="absolute inset-0 flex items-center justify-center bg-black/20 opacity-0 hover:opacity-100 transition-opacity duration-300"
                      aria-label="Watch talk"
                    >
                      <div class="w-16 h-16 rounded-full bg-white/90 flex items-center justify-center shadow-lg">
                        <svg
                          class="w-7 h-7 ml-1"
                          style={`color: ${siteConfig.accentColor}`}
                          fill="currentColor"
                          viewBox="0 0 24 24"
                        >
                          <path d="M8 5v14l11-7z" />
                        </svg>
                      </div>
                    </a>
                  )}
                </div>

                <div class="flex flex-col flex-1 p-6 gap-3">
                  {/* Event badge */}
                  <div class="flex flex-wrap items-center gap-2 text-xs font-medium text-gray-500 dark:text-gray-400">
                    <span
                      class="px-3 py-1 rounded-full text-white text-xs font-semibold"
                      style={`background-color: ${siteConfig.accentColor}`}
                    >
                      Talk
                    </span>
                    <span>{talk.event}</span>
                  </div>

                  {/* Title */}
                  <h3 class="text-lg font-bold text-gray-900 dark:text-gray-100 leading-snug">
                    {talk.title}
                  </h3>

                  {/* Meta */}
                  {(talk.date || talk.location) && (
                    <p class="text-xs text-gray-400 dark:text-gray-500 font-mono">
                      {[talk.date, talk.location].filter(Boolean).join(" · ")}
                    </p>
                  )}

                  {/* Description */}
                  <p class="text-sm text-gray-600 dark:text-gray-400 leading-relaxed flex-1">
                    {talk.description}
                  </p>

                  {/* Links */}
                  {activeLinks.length > 0 && (
                    <div class="flex flex-wrap gap-x-4 gap-y-1 pt-3 border-t border-gray-100 dark:border-gray-700">
                      {activeLinks.map(([type, url]) => (
                        <a
                          href={url}
                          target="_blank"
                          rel="noopener noreferrer"
                          class="text-sm font-semibold transition-colors duration-200 hover:underline"
                          style={`color: ${siteConfig.accentColor}`}
                        >
                          {linkLabels[type] ?? type} &rarr;
                        </a>
                      ))}
                    </div>
                  )}
                </div>
              </div>
            );
          })}
        </div>
      </div>
    </section>
  )
}
