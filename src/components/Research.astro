---
import { siteConfig } from "../config";
const hasResearch = siteConfig.research && siteConfig.research.length > 0;
---

{
  hasResearch && (
    <section id="research" class="p-8 sm:p-12 md:p-16 lg:p-24">
      <div>
        <h2 class="text-3xl sm:text-4xl md:text-5xl xl:text-7xl font-bold text-gray-900 mb-3">
          Research
        </h2>
        <div
          class="w-[75px] h-[5px] mb-10 rounded-full"
          style={`background-color: ${siteConfig.accentColor}`}
        />

        <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-6">
          {siteConfig.research.map((paper) => {
            const activeLinks = Object.entries(paper.links).filter(([, v]) => v);
            return (
              <div class="flex flex-col bg-white rounded-2xl border border-gray-200 overflow-hidden shadow-sm hover:shadow-md transition-shadow duration-300">
                {/* Placeholder image area */}
                <div
                  class="h-44 flex items-center justify-center text-xs text-gray-400 font-mono"
                  style={`background: linear-gradient(135deg, ${siteConfig.accentColor}18 0%, ${siteConfig.accentColor}08 100%)`}
                >
                  Preview coming soon
                </div>

                <div class="flex flex-col flex-1 p-6 gap-3">
                  {/* Badges */}
                  <div class="flex flex-wrap gap-2">
                    <span
                      class="px-3 py-1 rounded-full text-xs font-semibold text-white"
                      style={`background-color: ${siteConfig.accentColor}`}
                    >
                      {paper.venue}
                    </span>
                    {paper.award && (
                      <span class="px-3 py-1 rounded-full text-xs font-semibold border border-gray-300 text-gray-600">
                        {paper.award}
                      </span>
                    )}
                  </div>

                  {/* Title */}
                  <h3 class="text-lg font-bold text-gray-900 leading-snug">
                    {paper.title}
                  </h3>

                  {/* Description */}
                  <p class="text-sm text-gray-600 leading-relaxed flex-1">
                    {paper.description}
                  </p>

                  {/* Links */}
                  {activeLinks.length > 0 && (
                    <div class="flex flex-wrap gap-x-4 gap-y-1 pt-2 border-t border-gray-100">
                      {activeLinks.map(([type, url]) => (
                        <a
                          href={url}
                          target="_blank"
                          rel="noopener noreferrer"
                          class="text-sm font-semibold capitalize transition-colors duration-200 hover:underline"
                          style={`color: ${siteConfig.accentColor}`}
                        >
                          {type} &rarr;
                        </a>
                      ))}
                    </div>
                  )}
                </div>
              </div>
            );
          })}
        </div>
      </div>
    </section>
  )
}
